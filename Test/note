from langchain_community.tools import DuckDuckGoSearchResults
from langchain_community.utilities import DuckDuckGoSearchAPIWrapper

ddg_news_wrapper = DuckDuckGoSearchAPIWrapper(
    source="news",      # IMPORTANT: pulls from news results
    max_results=10,     # number of articles per query
    region="wt-wt",     
    time="m"            # optional: d=day, w=week, m=month, y=year
)

search_ddg = DuckDuckGoSearchResults(
    api_wrapper=ddg_news_wrapper,
    max_results=10,
    output_format="list"  # 'list' returns Python list of dicts; 'json' returns JSON string
)