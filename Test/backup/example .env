NVIDIA_API_KEY=<your Nvidia API key here> #Replace with your Nvidia API key if using NVIDIA's LLMs
SERPER_API_KEY=<your Serper API key here> #Replace with your Serper API key for web search capabilities
OTEL_SDK_DISABLED=true
OPENAI_API_KEY=<your OpenAI API key here> #Replace with your OpenAI API key or Nvidia API key if using NVIDIA's LLMs
CREWAI_TRACING_ENABLED=true
NVIDIA_ENDPOINT=https://integrate.api.nvidia.com/v1
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<email address here> #Your Gmail address for sending emails
SMTP_PASSWORD=<app password here> #16 character app password generated from Google account for secure email sending