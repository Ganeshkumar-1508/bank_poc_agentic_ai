# =============================================================================
# COUNTRIES-STATES-CITIES API ENDPOINTS
# =============================================================================

def get_countries_api(request):
    """
    API endpoint to get all countries.
    Returns JSON with country code, name, emoji, and currency.
    """
    if not COUNTRYSATECITY_AVAILABLE:
        return JsonResponse({'error': 'countrystatecity-countries package not installed'}, status=503)
    
    try:
        countries = get_countries()
        countries_data = [
            {
                'code': c.iso2,
                'name': c.name,
                'emoji': c.emoji or '🌐',
                'currency': c.currency_symbol or '$',
            }
            for c in countries
        ]
        return JsonResponse({'countries': countries_data})
    except Exception as e:
        logger.error(f"Error getting countries: {e}")
        return JsonResponse({'error': str(e)}, status=500)


def get_states_api(request):
    """
    API endpoint to get states for a specific country.
    Query params: country_code (ISO2 code, e.g., 'US', 'IN')
    Returns JSON with state id, name, and state_code.
    """
    if not COUNTRYSATECITY_AVAILABLE:
        return JsonResponse({'error': 'countrystatecity-countries package not installed'}, status=503)
    
    country_code = request.GET.get('country_code', '').upper()
    if not country_code:
        return JsonResponse({'error': 'country_code parameter is required'}, status=400)
    
    try:
        states = get_states_of_country(country_code)
        states_data = [
            {
                'id': s.id,
                'name': s.name,
                'state_code': s.state_code,
            }
            for s in states
        ]
        return JsonResponse({'states': states_data})
    except Exception as e:
        logger.error(f"Error getting states for country {country_code}: {e}")
        return JsonResponse({'error': str(e)}, status=500)


def get_cities_api(request):
    """
    API endpoint to get cities for a specific state.
    Query params: country_code (ISO2), state_code (state code)
    Returns JSON with city id and name.
    """
    if not COUNTRYSATECITY_AVAILABLE:
        return JsonResponse({'error': 'countrystatecity-countries package not installed'}, status=503)
    
    country_code = request.GET.get('country_code', '').upper()
    state_code = request.GET.get('state_code', '').upper()
    
    if not country_code or not state_code:
        return JsonResponse({'error': 'country_code and state_code parameters are required'}, status=400)
    
    try:
        cities = get_cities_of_state(country_code, state_code)
        cities_data = [
            {'id': c.id, 'name': c.name}
            for c in cities
        ]
        return JsonResponse({'cities': cities_data})
    except Exception as e:
        logger.error(f"Error getting cities for {country_code}-{state_code}: {e}")
        return JsonResponse({'error': str(e)}, status=500)


# =============================================================================
# CREWAI ENDPOINT 1: FD Advisor Crew API
# =============================================================================

@csrf_exempt
def fd_advisor_crew_api(request):
    """
    FD Advisor Crew API - Dynamic bank rates via CrewAI
    
    Uses create_td_fd_agents() + create_td_fd_tasks() to analyze
    FD rates across banks and provide recommendations.
    
    POST /api/fd-advisor-crew/
    Body: {
        "region": "India" (default),
        "tenure_months": 12 (default),
        "amount": 100000 (optional)
    }
    """
    if request.method != 'POST':
        return JsonResponse({'error': 'Method not allowed'}, status=405)
    
    if not CREWAI_AVAILABLE:
        return JsonResponse({'error': 'CrewAI not available'}, status=503)
    
    try:
        data = json.loads(request.body)
        region = data.get('region', 'India')
        tenure_months = int(data.get('tenure_months', 12))
        amount = float(data.get('amount', 100000))
        
        logger.info(f"FD Advisor Crew: region={region}, tenure={tenure_months}, amount={amount}")
        
        # Create and run crew
        agents = create_td_fd_agents()
        tasks = create_td_fd_tasks(agents, region=region, tenure=tenure_months)
        crew = Crew(
            agents=list(agents.values()),
            tasks=tasks,
            process=Process.sequential,
            verbose=False
        )
        output = crew.kickoff(inputs={'region': region, 'tenure_months': tenure_months})
        
        # Parse output
        raw_output = parse_crew_output(output)
        
        return JsonResponse(format_crew_response({
            'region': region,
            'tenure_months': tenure_months,
            'amount': amount,
            'result': raw_output,
            'crew_type': 'fd_advisor'
        }))
        
    except ImportError as e:
        logger.error(f"FD Advisor Crew import error: {e}")
        return JsonResponse({'error': f'CrewAI functions not available: {str(e)}'}, status=503)
    except Exception as e:
        logger.error(f"FD Advisor Crew error: {e}")
        return JsonResponse({'error': str(e)}, status=500)


