@csrf_exempt
def credit_risk_crew_api(request):
    """
    Credit Risk Crew API - ML + CrewAI enhanced analysis
    
    Uses create_credit_risk_agents() + create_credit_risk_tasks()
    with optional ML model integration.
    
    POST /api/credit-risk-crew/
    Body: {
        "applicant_income": 600000,
        "coapplicant_income": 0,
        "credit_score": 720,
        "dti_ratio": 35,
        "loan_amount": 500000,
        "loan_term": 36,
        "collateral_value": 0,
        "savings": 50000
    }
    """
    if request.method != 'POST':
        return JsonResponse({'error': 'Method not allowed'}, status=405)
    
    if not CREWAI_AVAILABLE:
        return JsonResponse({'error': 'CrewAI not available'}, status=503)
    
    try:
        data = json.loads(request.body)
        
        # Prepare borrower JSON for crew
        borrower_json = json.dumps({
            'applicant_income': data.get('applicant_income', 0),
            'coapplicant_income': data.get('coapplicant_income', 0),
            'credit_score': data.get('credit_score', 0),
            'dti_ratio': data.get('dti_ratio', 0),
            'loan_amount': data.get('loan_amount', 0),
            'loan_term': data.get('loan_term', 0),
            'collateral_value': data.get('collateral_value', 0),
            'savings': data.get('savings', 0)
        })
        
        logger.info(f"Credit Risk Crew: borrower_data={borrower_json[:100]}...")
        
        # Create and run crew
        agents = create_credit_risk_agents()
        tasks = create_credit_risk_tasks(agents, borrower_json=borrower_json)
        crew = Crew(
            agents=list(agents.values()),
            tasks=tasks,
            process=Process.sequential,
            verbose=False
        )
        output = crew.kickoff(inputs={'borrower_json': borrower_json})
        
        # Parse output
        raw_output = parse_crew_output(output)
        
        return JsonResponse(format_crew_response({
            'result': raw_output,
            'crew_type': 'credit_risk'
        }))
        
    except ImportError as e:
        logger.error(f"Credit Risk Crew import error: {e}")
        return JsonResponse({'error': f'CrewAI functions not available: {str(e)}'}, status=503)
    except Exception as e:
        logger.error(f"Credit Risk Crew error: {e}")
        return JsonResponse({'error': str(e)}, status=500)


