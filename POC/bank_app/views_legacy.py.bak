@csrf_exempt
def fd_template_crew_api(request):
    """
    FD Template Crew API - Generate customized FD templates and recommendations
    
    Uses create_fd_template_agents() + create_fd_template_tasks()
    
    POST /api/fd-template/
    Body: {
        "customer_name": "John Doe",
        "fd_number": "FD123456",
        "bank_name": "HDFC Bank",
        "amount": 500000,
        "rate": 7.5,
        "tenure": 12,
        "maturity_date": "2025-01-15",
        "maturity_amount": 537500,
        "template_type": "confirmation" (or "maturity_reminder", "renewal_offer")
    }
    """
    if request.method != 'POST':
        return JsonResponse({'error': 'Method not allowed'}, status=405)
    
    if not CREWAI_AVAILABLE:
        return JsonResponse({'error': 'CrewAI not available'}, status=503)
    
    try:
        data = json.loads(request.body)
        
        # Prepare FD data
        fd_data = {
            'customer_name': data.get('customer_name', ''),
            'fd_number': data.get('fd_number', ''),
            'bank_name': data.get('bank_name', ''),
            'amount': data.get('amount', 0),
            'rate': data.get('rate', 0),
            'tenure': data.get('tenure', 0),
            'maturity_date': data.get('maturity_date', ''),
            'maturity_amount': data.get('maturity_amount', 0),
            'customer_email': data.get('customer_email', ''),
            'opening_date': data.get('opening_date', '')
        }
        template_type = data.get('template_type', 'confirmation')
        
        logger.info(f"FD Template Crew: fd_number={fd_data.get('fd_number')}, template_type={template_type}")
        
        # Create and run crew
        agents = create_fd_template_agents()
        tasks = create_fd_template_tasks(agents, fd_data, template_type)
        crew = Crew(
            agents=[agents['fd_template_generator_agent']],
            tasks=tasks,
            process=Process.sequential,
            verbose=False
        )
        output = crew.kickoff(inputs={'fd_data': fd_data, 'template_type': template_type})
        
        # Parse output
        raw_output = parse_crew_output(output)
        
        return JsonResponse(format_crew_response({
            'fd_number': fd_data.get('fd_number'),
            'template_type': template_type,
            'result': raw_output,
            'crew_type': 'fd_template'
        }))
        
    except ImportError as e:
        logger.error(f"FD Template Crew import error: {e}")
        return JsonResponse({'error': f'CrewAI functions not available: {str(e)}'}, status=503)
    except Exception as e:
        logger.error(f"FD Template Crew error: {e}")
        return JsonResponse({'error': str(e)}, status=500)


